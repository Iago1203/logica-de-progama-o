programa {
  funcao inicio() {
    inteiro numero , contador = 0
    caracter resposta

    faca {
    escreva("Digite um número \n")
    leia(numero)

    se ( numero > 0 )
    escreva("Número positivo ")

    se(numero == 0 )
    escreva("Número 0 ")
    
    senao 

    escreva("Numero negativo ")
    
  contador++
    
    escreva("Deseja continuar(s ou n) ")
    leia (resposta)
    }enquanto( resposta =="s")
    

  }
}
