programa
{
    funcao inicio()
    {
        real  largura, altura
        real area
        escreva("Largura: ")

        leia(largura)
        escreva("Altura: ")
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }  //  Erro de usabilidade pois  não possuia escreva a largura e altura
       //  Erro de usabilidade pois a variavel estava inteiro  
}