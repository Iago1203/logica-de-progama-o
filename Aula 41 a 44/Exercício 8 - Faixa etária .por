programa
{
    funcao inicio()
    {
        inteiro idade
        escreva("Informe a idade: ")
        leia(idade)

        se (idade >= 12 e  idade <= 17)
        {
            escreva("Adolescente")
        }
        senao
        {
            escreva("Não é adolescente")
        } // Operador lógico errado
          // Não posuia escreva 
    }
}