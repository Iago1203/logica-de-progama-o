programa
{
    funcao inicio()
    {
        inteiro numero
        escreva("Informe um número: ")
        leia(numero)

        se (numero > 0)
        {
            escreva("Numero positivo")
        }
    }    // O operardor matemático estava errado < (Menor), seria o > (Maior) 
        // Novamente esta sem o escreva    

}