programa
{
    funcao inicio()
    {
        real n1, n2, media
        escreva("Primeiro número: ", "\n" )
        leia(n1)
        escreva("Segundo número: ", "\n")
        leia(n2)

        media = (n1 + n2) / 3

        escreva("Média: ", media)
        //  Erro de usabilidade pois  não possuia escreva o primeiro número
        //  Erro de usabilidadae poi não possuia  escreva o segundo número

    }
}