programa {
  funcao inicio() {
   cadeia nome , apto , saude 
   caracter sexo, s, n
   inteiro idade, contador = 0

   faca{

   escreva("Nome: ")
   leia (nome)
   
   escreva("Idade: ")
   leia (idade)

   escreva("Estado de saúde: ")
   leia (saude)

   escreva("Sexo: ")
   leia (sexo)
   se (idade >= 18 e saude == "apto")
    contador++} 
    enquanto(s e n == "s")
     escreva("deseja continuar cadastrando (s o n): ")
     
    


  }
}
