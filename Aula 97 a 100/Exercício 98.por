programa {
  funcao real calcularMedia(real nota1 , real nota2){
  real media , soma
  retorne media
  }
  
  funcao inicio() {
    real nota1, nota2, media 
    media  = (nota1 + nota2) /2
    escreva("Primeira nota: ")
    leia(nota1)

    escreva("Segunda nota: ")
    leia(nota2)

    escreva("Medía das nota: ", calcularMedia(media ))
  }
}
