programa {
  funcao real circunferenciaDoCirculo(real raio){
    real circunferencia = 2 * 3.14 * raio

    retorne circunferencia 
  }
  funcao inicio() {
    real raio 

    escreva("informe o raio: ")
    leia(raio)

    escreva("circunfêrencia do círculo: ", circunferenciaDoCirculo(raio))
  }
}
