programa {
  funcao inicio() {
    inteiro numero[4] = {15, 20, 5,10}, soma, multiplicacao, diferenca
    soma = numero[0] + numero[3]
    escreva("Soma: ", soma, "\n")

    multiplicacao = numero[1] * numero[2]
    escreva("Multiplicação: ", multiplicacao, "\n")

    diferenca = numero[2] - numero[0]
    escreva("Diferença: ", diferenca)

  }
}
