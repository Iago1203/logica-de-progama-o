programa {
  funcao inicio() {
    inteiro numeros[5]
    numeros[0]
    numeros[1]
    numeros[2]
    numeros[3] = 6
    numeros[4] = 8
  

    escreva("Primeiro número: ", "\n")
    leia(numeros[0])
    escreva("Segundo número:" ,"\n")
    leia(numeros[1])
    escreva("Terceiro número:" ,"\n" )
    leia(numeros[2])

    escreva("Outros valores: ", numeros[3], "\n")
    escreva("Outros valores: ", numeros[4], "\n")
  }
}
